{
  "name": "shenny-test-showcase",
  "version": "0.1.0",
  "private": true,
  "description": "Read-quality test showcase demonstrating API contract tests, DB integration tests, load tests, and BDD/Cucumber across a Next.js application.",
  "scripts": {
    "test:api": "vitest run src/__tests__/api",
    "test:api:watch": "vitest src/__tests__/api",
    "test:api:coverage": "vitest run src/__tests__/api --coverage",
    "test:db": "vitest run src/__tests__/db",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts tests/e2e/keyboard-navigation.spec.ts tests/e2e/focus-visibility.spec.ts tests/e2e/aria-semantics.spec.ts",
    "test:cucumber": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber-js --config tests/cucumber/support/cucumber.config.ts",
    "test:cucumber:smoke": "node --import tsx/esm node_modules/@cucumber/cucumber/bin/cucumber-js --config tests/cucumber/support/cucumber.config.ts --tags @smoke",
    "test:load": "npm run k6:build && k6 run tests/load/dist/rate-limiter.js",
    "test:all": "npm run test:api && npm run test:db && npm run test:e2e",
    "docker:up": "docker compose up -d postgres-test",
    "docker:down": "docker compose down",
    "k6:build": "esbuild tests/load/scenarios/rate-limiter.ts tests/load/scenarios/entries.ts tests/load/scenarios/auth.ts tests/load/scenarios/ai-routes.ts --bundle --outdir=tests/load/dist --platform=browser --format=esm --target=es2017 --external:k6 --external:k6/*"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@clerk/nextjs": "^7.3.3",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stripe/stripe-js": "^9.6.0",
    "@types/papaparse": "^5.5.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "openai": "^6.37.0",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "svix": "^1.93.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@clerk/testing": "^2.0.32",
    "@cucumber/cucumber": "^13.0.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/cucumber": "^6.0.1",
    "@types/k6": "^2.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "axe-core": "^4.11.4",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.61.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
